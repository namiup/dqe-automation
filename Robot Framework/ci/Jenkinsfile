pipeline {
    agent any
    environment {
    POSTGRES_SECRET = credentials('jenkins-postgres-credentials')
    }
    stages {
        stage('Update Packages') {
            steps {
                script {
                    // Update the package list
                    sh 'apt-get update'
                    sh 'apt-get install -y libpq-dev'
                }
            }
        }
        stage('Install Python') {
            steps {
                // Install Python and pip
                sh 'apt-get install -y python3 python3-pip python3-venv'
            }
        }
        stage('Clone Repository') {
            steps {
                script {
                    // Clone the Git repository
                    git branch: 'main', url: 'https://github.com/namiup/dqe-automation/'
                }
            }
        }
        stage('Install Dependencies') {
            steps {
                script {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                        pip install -r 'Robot Framework'/requirements.txt
                    '''
                }
            }
        }
        stage('Run main') {
            steps {
                script {
                    // Activate the virtual environment, set PYTHONPATH, and run the script
                    sh '''
                        . venv/bin/activate
                        export PYTHONPATH=$WORKSPACE
                        python data_dev/main.py
                    '''
                }
            }
        }
        stage('Install Chrome and ChromeDriver') {
            steps {
                sh '''
                    set -e
        
                    # Install dependencies
                    apt-get update
                    apt-get install -y wget gnupg unzip curl \
                        libnss3 libxi6 libxcursor1 libxss1 libxcomposite1 libxrandr2 libasound2 libatk1.0-0 libatk-bridge2.0-0 libgtk-3-0
        
                    # Add Google Chrome repository and install Chrome
                    wget -q -O - https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor > /etc/apt/trusted.gpg.d/google-chrome.gpg
                    echo "deb [arch=amd64] http://dl.google.com/linux/chrome/deb/ stable main" > /etc/apt/sources.list.d/google-chrome.list
                    apt-get update
                    apt-get install -y google-chrome-stable
        
                    # Get Chrome version
                    CHROME_VERSION=$(google-chrome --version | grep -oP '\\d+\\.\\d+\\.\\d+')
                    CHROME_MAJOR_VERSION=$(echo $CHROME_VERSION | cut -d. -f1)
        
                    # Get matching ChromeDriver version
                    DRIVER_VERSION=$(curl -s "https://chromedriver.storage.googleapis.com/LATEST_RELEASE_$CHROME_MAJOR_VERSION")
        
                    # Download and install ChromeDriver
                    wget -O /tmp/chromedriver.zip "https://chromedriver.storage.googleapis.com/${DRIVER_VERSION}/chromedriver_linux64.zip"
                    unzip -o /tmp/chromedriver.zip -d /usr/local/bin/
                    chmod +x /usr/local/bin/chromedriver
                    rm /tmp/chromedriver.zip
        
                    # Verify versions
                    echo "Google Chrome version: $(google-chrome --version)"
                    echo "ChromeDriver version: $(chromedriver --version)"
                '''
            }
        }                                                
        stage('Run Tests') {
            steps {
                script {
                    sh '''
                        . venv/bin/activate
                        robot --include smoke 'Robot Framework/test.robot'
                    '''
                }
            }
        }
    }
    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'Pipeline executed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs for details.'
        }
    }
}
