pipeline {
    agent any
    environment {
        CHROME_VERSION = '148.0.7778.56'
    }
    stages {
        stage('Install ChromeDriver') {
            steps {
                script {
                    sh '''
                        # Download ChromeDriver binary
                        echo "Downloading ChromeDriver for Chrome version ${CHROME_VERSION}..."
                        wget https://storage.googleapis.com/chrome-for-testing-public/${CHROME_VERSION}/linux64/chromedriver-linux64.zip -O chromedriver-linux64.zip

                        # Extract the binary and overwrite existing files
                        echo "Extracting ChromeDriver..."
                        unzip -o chromedriver-linux64.zip -d /usr/local/bin

                        # Move the chromedriver binary to /usr/local/bin
                        echo "Moving ChromeDriver binary to /usr/local/bin..."
                        mv /usr/local/bin/chromedriver-linux64/chromedriver /usr/local/bin/

                        # Clean up the extracted folder
                        echo "Cleaning up..."
                        rm -rf /usr/local/bin/chromedriver-linux64
                        rm -f chromedriver-linux64.zip

                        # Set permissions
                        echo "Setting permissions for ChromeDriver..."
                        chmod +x /usr/local/bin/chromedriver

                        # Verify the installed version
                        echo "Verifying ChromeDriver installation..."
                        chromedriver --version
                    '''
                }
            }
        }
    }
    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'ChromeDriver installed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs for details.'
        }
    }
}
