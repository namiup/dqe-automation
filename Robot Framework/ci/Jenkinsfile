pipeline {
    agent any
    stages {
        stage('Install Chrome for Testing') {
            steps {
                script {
                    sh '''
                        # Update package lists and install dependencies
                        apt-get update
                        apt-get install -y wget unzip xvfb

                        # Download Chrome for Testing binary
                        wget https://storage.googleapis.com/chrome-for-testing-public/148.0.7778.56/linux64/chrome-linux64.zip -O chrome-linux64.zip

                        # Extract the binary
                        unzip chrome-linux64.zip -d /opt/google/chrome

                        # Create a symbolic link
                        ln -sf /opt/google/chrome/chrome-linux64/chrome /usr/bin/google-chrome

                        # Clear old Chrome cache
                        rm -rf ~/.cache/google-chrome
                        rm -rf ~/.config/google-chrome

                        # Verify the installed version
                        google-chrome --version
                    '''
                }
            }
        }
        stage('Install ChromeDriver') {
            steps {
                script {
                    sh '''
                        # Download ChromeDriver binary
                        wget https://storage.googleapis.com/chrome-for-testing-public/148.0.7778.56/linux64/chromedriver-linux64.zip -O chromedriver-linux64.zip

                        # Extract the binary
                        unzip chromedriver-linux64.zip -d /usr/local/bin

                        # Set permissions
                        chmod +x /usr/local/bin/chromedriver

                        # Verify the installed version
                        chromedriver --version
                    '''
                }
            }
        }

    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'Chrome for Testing and ChromeDriver installed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs for details.'
        }
    }
}
