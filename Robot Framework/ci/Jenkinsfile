pipeline {
    agent any
    environment {
        POSTGRES_SECRET = credentials('jenkins-postgres-credentials')
        PATH = "/usr/local/bin:$PATH"  // Add chromedriver path to PATH
    }
    stages {
        stage('Update Packages') {
            steps {
                script {
                    sh '''
                        #!/bin/bash
                        # Update the package list
                        apt-get update
                        
                        # Install required dependencies for Chrome and ChromeDriver
                        apt-get install -y libpq-dev libnss3 libxi6 libgdk-pixbuf-2.0-0 libxcomposite1 libxrandr2 libxdamage1 libxext6 libxshmfence1 libx11-xcb1 libxtst6 libegl1
                        
                        # Install libgconf-2-4 from an alternative source
                        wget http://security.ubuntu.com/ubuntu/pool/universe/g/gconf/libgconf-2-4_3.2.6-4ubuntu1_amd64.deb
                        dpkg -i libgconf-2-4_3.2.6-4ubuntu1_amd64.deb || apt-get install -f -y
                    '''
                }
            }
        }
        stage('Install Python') {
            steps {
                script {
                    sh '''
                        #!/bin/bash
                        # Install Python and pip
                        apt-get install -y python3 python3-pip python3-venv
                    '''
                }
            }
        }
        stage('Clone Repository') {
            steps {
                script {
                    // Clone the Git repository
                    git branch: 'main', url: 'https://github.com/namiup/dqe-automation/'
                }
            }
        }
        stage('Install Dependencies') {
            steps {
                script {
                    sh '''
                        #!/bin/bash
                        # Create a virtual environment and install dependencies
                        python3 -m venv venv
                        . venv/bin/activate  # Use . instead of source for compatibility with sh
                        pip install -r 'Robot Framework'/requirements.txt
                    '''
                }
            }
        }
        stage('Run main') {
            steps {
                script {
                    sh '''
                        #!/bin/bash
                        # Activate the virtual environment, set PYTHONPATH, and run the main script
                        . venv/bin/activate  # Use . instead of source for compatibility with sh
                        export PYTHONPATH=$WORKSPACE
                        python data_dev/main.py
                    '''
                }
            }
        }
        stage('Run Tests') {
            steps {
                script {
                    sh '''
                        #!/bin/bash
                        # Activate the virtual environment and run Robot Framework tests
                        . venv/bin/activate  # Use . instead of source for compatibility with sh
                        robot --include smoke --variable executable_path:/usr/local/bin/chromedriver --variable options:add_argument("--headless") 'Robot Framework/test.robot'
                    '''
                }
            }
        }
    }
    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'Pipeline executed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs for details.'
        }
    }
}
