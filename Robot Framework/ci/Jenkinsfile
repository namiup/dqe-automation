pipeline {
    agent any
    environment {
        POSTGRES_SECRET = credentials('jenkins-postgres-credentials')
    }
    stages {
        stage('Update Packages') {
            steps {
                script {
                    sh '''
                        # Update package lists and install dependencies
                        apt-get update
                        apt-get install -y curl gnupg wget

                        # Add Google Chrome repository
                        wget -q -O - https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor > /usr/share/keyrings/google-chrome.gpg
                        echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" > /etc/apt/sources.list.d/google-chrome.list

                        # Update package list again to include the Chrome repository
                        apt-get update

                        # Install or upgrade Google Chrome to the latest version
                        apt-get install -y google-chrome-stable

                        # Verify the installed version of Google Chrome
                        google-chrome --version
                    '''
                }
            }
        }
        stage('Install Python') {
            steps {
                sh 'apt-get install -y python3 python3-pip python3-venv'
            }
        }
        stage('Clone Repository') {
            steps {
                script {
                    git branch: 'main', url: 'https://github.com/namiup/dqe-automation/'
                }
            }
        }
        stage('Install Dependencies') {
            steps {
                script {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                    '''
                }
            }
        }
        stage('Run Tests') {
            steps {
                script {
                    sh '''
                        # Start a virtual display for headless Chrome
                        Xvfb :99 -ac &
                        export DISPLAY=:99

                        # Activate the virtual environment and run Robot Framework tests
                        . venv/bin/activate
                        // robot --include smoke 'Robot Framework/test.robot'
                    '''
                }
            }
        }
    }
    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'Pipeline executed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs for details.'
        }
    }
}
