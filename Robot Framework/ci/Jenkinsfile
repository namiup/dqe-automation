pipeline {
    agent any
    stages {
        stage('Install Chrome for Testing') {
            steps {
                script {
                    sh '''
                        # Update package lists and install dependencies
                        apt-get update
                        apt-get install -y wget unzip

                        # Download Chrome for Testing binary
                        wget https://storage.googleapis.com/chrome-for-testing-public/148.0.7778.56/linux64/chrome-linux64.zip -O chrome-linux64.zip

                        # Extract the binary
                        unzip chrome-linux64.zip -d /opt/google/chrome

                        # Create a symbolic link
                        ln -sf /opt/google/chrome/chrome-linux64/chrome /usr/bin/google-chrome

                        # Clear old Chrome cache
                        rm -rf ~/.cache/google-chrome
                        rm -rf ~/.config/google-chrome

                        # Verify the installed version
                        google-chrome --version
                    '''
                }
            }
        }
    }
    stage('Install Python') {
            steps {
                sh 'apt-get install -y python3 python3-pip python3-venv'
            }
        }
        stage('Clone Repository') {
            steps {
                script {
                    git branch: 'main', url: 'https://github.com/namiup/dqe-automation/'
                }
            }
        }
        stage('Install Dependencies') {
            steps {
                script {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                    '''
                }
            }
        }
        stage('Run Tests') {
            steps {
                script {
                    sh '''
                        # Start a virtual display for headless Chrome
                        Xvfb :99 -ac &
                        export DISPLAY=:99

                        # Activate the virtual environment and run Robot Framework tests
                        . venv/bin/activate
                        robot --include smoke 'Robot Framework/test.robot'
                    '''
                }
            }
        }
    }
    post {
        always {
            echo 'Pipeline execution completed.'
        }
        success {
            echo 'Chrome for Testing installed successfully!'
        }
        failure {
            echo 'Failed to install Chrome for Testing. Please check the logs for details.'
        }
    }
}
